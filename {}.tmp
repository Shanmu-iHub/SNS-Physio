<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="../static/images/Favicon.png?v=2">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Brochure | SNS College of Physiotherapy - Design Thinking Physiotherapy College Coimbatore</title>
    <meta name="description"
        content="SNS College of Physiotherapy - India's first Design Thinking Physiotherapy college in Coimbatore. Bachelor and Master of Physiotherapy (B.P.T & M.P.T) with world-class facilities.">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#f4f5f9',
                            100: '#e8eaf2',
                            200: '#d1d5e6',
                            300: '#babfd9',
                            400: '#a4a9cc',
