                            50: '#f4f5f9',
                            100: '#e8eaf2',
                            200: '#d1d5e6',
                            300: '#babfd9',
                            400: '#a4a9cc',
                            500: '#9298CB',
                            600: '#7a7fac',
                            700: '#62668d',
                            800: '#4b4e6e',
