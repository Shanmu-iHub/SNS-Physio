                <div class="bg-white p-8 rounded-2xl shadow-lg card-hover">
                    <i class="fas fa-graduation-cap text-4xl text-purple-600 mb-4"></i>
                    <h3 class="text-xl font-bold mb-2">Academic & Research</h3>
                    <p class="text-gray-600">Pursue teaching roles in medical colleges or engage in cutting-edge
                        research.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-gradient-to-r from-primary-600 to-primary-800 text-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
