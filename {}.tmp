<body class="antialiased">
    <app-header></app-header>

    <!-- Hero Section -->
    <section class="relative h-[40vh] min-h-[400px] flex items-center justify-center text-white overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="/static/images/physio/7.jpg" alt="B.P.T Program" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-black/30"></div>
        </div>

        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <nav class="mb-6">
                <div class="flex items-center justify-center space-x-2 text-sm text-white/80">
                    <a href="/" class="hover:text-white transition">Home</a>
                    <i class="fas fa-chevron-right text-xs"></i>
                    <span class="text-white">Undergraduate (B.P.T)</span>
                </div>
            </nav>
            <h1 class="text-4xl lg:text-6xl font-extrabold mb-6 leading-tight">Bachelor of Physiotherapy (B.P.T)</h1>
            <p class="text-xl lg:text-2xl text-white/90 max-w-4xl mx-auto leading-relaxed">A 4.5-year comprehensive
                journey to becoming a skilled healthcare professional with a 6-month compulsory clinical internship.</p>
            <div class="mt-8 flex justify-center">
                <div class="w-24 h-1 bg-primary-500 rounded-full"></div>
            </div>
        </div>
    </section>

    <!-- Program Overview -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-4xl font-bold mb-6 text-gray-900">Program Overview</h2>
                    <p class="text-lg text-gray-700 leading-relaxed mb-6">
                        The Bachelor of Physiotherapy (B.P.T) at SNS College of Physiotherapy is designed to provide
                        students with an in-depth understanding of human anatomy, physiology, and the therapeutic
                        practices required for physical rehabilitation. Our curriculum is uniquely enhanced with
                        <strong>Design Thinking</strong>, enabling students to innovate patient care.
                    </p>
                    <p class="text-lg text-gray-700 leading-relaxed">
                        Students gain hands-on experience through clinical postings in multi-specialty hospitals
                        starting from their early years, ensuring they are well-prepared for real-world medical
                        challenges.
                    </p>
                </div>
                <div class="bg-primary-50 rounded-2xl p-8 shadow-inner">
                    <h3 class="text-2xl font-bold mb-6 text-primary-700">Course Highlights</h3>
                    <ul class="space-y-4 text-gray-800 font-medium">
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mt-1 mr-3"></i>
                            <span>4-Year Academic Study + 6 Months Internship</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mt-1 mr-3"></i>
                            <span>Clinical Training in Multi-specialty Hospitals</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mt-1 mr-3"></i>
                            <span>Advanced Labs & Modern Equipment</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mt-1 mr-3"></i>
                            <span>Research-oriented Skill Development</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mt-1 mr-3"></i>
                            <span>Design Thinking in Healthcare Practice</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Career Opportunities -->
    <section class="py-16 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold text-gray-900 mb-4">Career Opportunities</h2>
                <p class="text-xl text-gray-600">The field of Physiotherapy offers diverse and rewarding career paths
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-white p-8 rounded-2xl shadow-lg card-hover">
                    <i class="fas fa-hospital text-4xl text-primary-600 mb-4"></i>
                    <h3 class="text-xl font-bold mb-2">Clinical Practice</h3>
                    <p class="text-gray-600">Work in major hospitals, private clinics, and rehabilitation centers.</p>
                </div>
                <div class="bg-white p-8 rounded-2xl shadow-lg card-hover">
                    <i class="fas fa-running text-4xl text-green-600 mb-4"></i>
                    <h3 class="text-xl font-bold mb-2">Sports Physiotherapy</h3>
                    <p class="text-gray-600">Join sports teams, fitness centers, and athlete management organizations.
                    </p>
