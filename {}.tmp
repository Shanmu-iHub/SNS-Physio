                        <i class="fas fa-building text-3xl text-pink-600"></i>
                    </div>
                    <h3 class="font-bold text-lg text-center mb-3">Real Estate</h3>
                    <p class="text-sm text-gray-600 text-center">PropTech, smart buildings, analytics</p>
