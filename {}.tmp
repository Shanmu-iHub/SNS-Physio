                            300: '#babfd9',
                            400: '#a4a9cc',
                            500: '#9298CB',
                            600: '#7a7fac',
                            700: '#62668d',
                            800: '#4b4e6e',
                            900: '#33354f',
                            DEFAULT: '#9298CB',
                        }
                    }
                }
            }
        }
    </script>


    <!-- Font Awesome -->
    <link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css" rel="stylesheet">

    <!-- Google Fonts -->
