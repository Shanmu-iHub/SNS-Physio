                width: 50px;
                height: 50px;
                bottom: 25px;
                right: 25px;
                font-size: 28px;
            }

            .instagram-float {
                width: 50px;
                height: 50px;
                bottom: 85px;
                right: 25px;
                font-size: 28px;
            }
        }
    </style>

